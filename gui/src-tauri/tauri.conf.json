{
  "productName": "DeepSeek Anthropic Gateway Manager",
  "version": "0.1.0",
  "identifier": "com.deepseek.anthropic-gateway-gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "DeepSeek Anthropic Gateway Manager",
        "width": 960,
        "height": 720,
        "resizable": true
      }
    ]
  }
}
